#. Plugin Name of the plugin
#: woo-stripe-express-by-country.php
msgid "Stripe Express Checkout by Country"
msgstr "Stripe Express Checkout per land"

#. Plugin URI of the plugin
#. Author URI of the plugin
#: woo-stripe-express-by-country.php
msgid "https://headwall-hosting.com/"
msgstr "https://headwall-hosting.com/"

#. Description of the plugin
#: woo-stripe-express-by-country.php
msgid "Restricts the WooCommerce Stripe Express Checkout (Apple Pay / Google Pay) to configurable countries, using an allow-list or block-list."
msgstr "Beperkt de WooCommerce Stripe Express Checkout (Apple Pay / Google Pay) tot instelbare landen, aan de hand van een lijst met toegestane of geblokkeerde landen."

#. Author of the plugin
#: woo-stripe-express-by-country.php
msgid "Paul Faulkner"
msgstr "Paul Faulkner"

#: admin-templates/settings-page.php:25
msgid "Control which customers are offered the Stripe Express Checkout (Apple Pay / Google Pay) based on their country. The customer country is taken from their shipping address, falling back to billing."
msgstr "Bepaal op basis van het land van de klant aan welke klanten Stripe Express Checkout (Apple Pay / Google Pay) wordt aangeboden. Het land van de klant wordt afgeleid uit het verzendadres; indien dat niet beschikbaar is, wordt het factuuradres gebruikt."

#: admin-templates/settings-page.php:35
msgctxt "restriction mode setting"
msgid "Mode"
msgstr "Modus"

#: admin-templates/settings-page.php:43
msgid "Only show express checkout for the selected countries"
msgstr "Toon alleen de snelle afrekenoptie voor de geselecteerde landen"

#: admin-templates/settings-page.php:51
msgid "Show express checkout for all customers, except the selected countries"
msgstr "Toon de snelle kassa voor alle klanten, behalve in de geselecteerde landen"

#: admin-templates/settings-page.php:61
msgctxt "country list setting"
msgid "Countries"
msgstr "Landen"

#: admin-templates/settings-page.php:68
msgid "The WooCommerce country list is unavailable. Please ensure WooCommerce is active."
msgstr "De landenlijst van WooCommerce is niet beschikbaar. Controleer of WooCommerce is ingeschakeld."

#: admin-templates/settings-page.php:74
msgid "Choose countries…"
msgstr "Kies landen…"

#: admin-templates/settings-page.php:88
msgid "Search for and select one or more countries. The selection is interpreted according to the mode above."
msgstr "Zoek één of meer landen en selecteer deze. De selectie wordt geïnterpreteerd volgens de hierboven beschreven modus."

#: admin-templates/settings-page.php:99
msgctxt "hard block setting"
msgid "Server-side block"
msgstr "Blok aan de serverzijde"

#: admin-templates/settings-page.php:106
msgid "Also reject disallowed express-checkout orders on the server"
msgstr "Weiger ook op de server bestellingen die via Express Checkout zijn geplaatst en niet zijn goedgekeurd"

#: admin-templates/settings-page.php:111
msgid "Optional. The display gate above already hides the buttons. Enable this only if you need to guarantee that a disallowed order can never complete via express checkout — note it can reject a wallet payment after the customer has started it, because their wallet country may differ from the country shown."
msgstr "Optioneel. De weergavebalk hierboven verbergt de knoppen al. Schakel deze optie alleen in als je er zeker van wilt zijn dat een niet-toegestane bestelling nooit via de snelle kassa kan worden afgerond — houd er rekening mee dat een betaling via een digitale portemonnee kan worden geweigerd nadat de klant deze heeft gestart, omdat het land van de portemonnee kan afwijken van het weergegeven land."

#: admin-templates/settings-page.php:119
msgid "Save Changes"
msgstr "Wijzigingen opslaan"

#: includes/class-plugin.php:94
#: includes/class-plugin.php:95
msgid "Stripe Express by Country"
msgstr "Stripe Express per land"

#: includes/class-restrictions.php:153
msgid "Express Checkout is not available for your country. Please complete your purchase using the standard checkout."
msgstr "Express Checkout is niet beschikbaar in uw land. Rond uw aankoop alstublieft af via de standaard afrekenprocedure."

#: includes/class-settings.php:128
msgid "You are not allowed to manage these settings."
msgstr "U hebt geen toestemming om deze instellingen te wijzigen."